{
  "name": "cdex-token-chatter",
  "version": "0.1.0",
  "description": "Orderly SDK plugin: live social chatter feed (Reddit + Farcaster + crypto news) for the active perp symbol, as a Chart | Chatter tab on the trading page. No host backend required.",
  "license": "MIT",
  "keywords": [
    "orderly",
    "orderly-plugin",
    "dex",
    "social-feed",
    "reddit",
    "farcaster",
    "crypto-news"
  ],
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "package.json",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@orderly.network/plugin-core": ">=3.0.0-beta.1",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@orderly.network/plugin-core": "^3.0.0",
    "@orderly.network/ts-config": "^0.0.2",
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.3.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tsup": "^8.5.1",
    "typescript": "^5.1.6"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alnany/cdex-token-chatter.git"
  },
  "homepage": "https://github.com/alnany/cdex-token-chatter#readme",
  "bugs": {
    "url": "https://github.com/alnany/cdex-token-chatter/issues"
  }
}